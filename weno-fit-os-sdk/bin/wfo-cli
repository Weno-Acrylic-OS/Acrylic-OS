#!/usr/bin/env node

const yargs = require('yargs/yargs');
const { hideBin } = require('yargs/helpers');
const fs = require('fs-extra');
const path = require('path');
const tar = require('tar');

yargs(hideBin(process.argv))
  .command('init <name>', 'Initialize a new Weno Fit OS project', (yargs) => {
    return yargs
      .positional('name', {
        describe: 'Name of the project to initialize',
        type: 'string'
      })
      .option('template', {
        alias: 't',
        describe: 'Choose a project template',
        choices: ['basic_app', 'notification_app'],
        default: 'basic_app'
      })
  }, (argv) => {
    const projectPath = path.join(process.cwd(), argv.name);
    const templatePath = path.join(__dirname, '..', 'templates', argv.template);
    
    fs.copySync(templatePath, projectPath);
    
    const appJsonPath = path.join(projectPath, 'app.json');
    const appJson = fs.readJsonSync(appJsonPath);
    appJson.name = argv.name;
    fs.writeJsonSync(appJsonPath, appJson, { spaces: 2 });

    console.log(`Project ${argv.name} initialized successfully from '${argv.template}' template.`);
  })
  .command('build', 'Build the application package', () => {}, (argv) => {
    const cwd = process.cwd();
    const appJsonPath = path.join(cwd, 'app.json');
    if (!fs.existsSync(appJsonPath)) {
      console.error('Error: app.json not found. Make sure you are in a Weno Fit OS project directory.');
      return;
    }
    const appJson = fs.readJsonSync(appJsonPath);
    const appName = appJson.name.replace(/\s+/g, '-').toLowerCase();
    const wfoFileName = `${appName}.wfo`;
    const distDir = path.join(cwd, 'dist');
    fs.ensureDirSync(distDir);
    const wfoFilePath = path.join(distDir, wfoFileName);

    tar.c(
      {
        gzip: true,
        file: wfoFilePath,
        cwd: cwd
      },
      ['app.json', 'index.js']
    ).then(() => {
      console.log(`Application package created at ${wfoFilePath}`);
    });
  })
  .command('sign <package>', 'Sign the application package', (yargs) => {
    return yargs
      .positional('package', {
        describe: 'Path to the application package',
        type: 'string'
      })
  }, (argv) => {
    const packagePath = path.resolve(argv.package);
    if (!fs.existsSync(packagePath)) {
      console.error(`Error: Package not found at ${packagePath}`);
      return;
    }
    fs.appendFileSync(packagePath, '\\n---SIGNATURE---');
    console.log(`Package ${packagePath} signed successfully.`);
  })
  .command('deploy <package>', 'Deploy the application package to the simulator', (yargs) => {
    return yargs
      .positional('package', {
        describe: 'Path to the application package',
        type: 'string'
      })
  }, (argv) => {
    const packagePath = path.resolve(argv.package);
    if (!fs.existsSync(packagePath)) {
      console.error(`Error: Package not found at ${packagePath}`);
      return;
    }
    const appName = path.basename(packagePath, '.wfo');
    const destDir = path.join(__dirname, '..', '..', 'third_party_apps', appName);
    fs.ensureDirSync(destDir);
    
    tar.x(
      {
        file: packagePath,
        cwd: destDir
      }
    ).then(() => {
      console.log(`App ${appName} deployed to simulator.`);
    });
  })
  .command('debug', 'Start a debug session', () => {}, (argv) => {
    console.log('Starting debug session...');
    // TODO: Implement debug process
  })
  .command('run-simulator', 'Run the Weno Fit OS simulator', () => {}, (argv) => {
    const { exec } = require('child_process');
    const rootPath = path.join(__dirname, '..', '..');
    console.log('Starting the Weno Fit OS simulator...');
    
    const child = exec('make run-web', { cwd: rootPath }, (error, stdout, stderr) => {
      if (error) {
        console.error(`Error starting simulator: ${error}`);
        return;
      }
      console.log(stdout);
      console.error(stderr);
    });

    child.on('exit', (code) => {
      console.log(`Simulator process exited with code ${code}`);
    });
  })
  .demandCommand(1, 'You need at least one command before moving on')
  .help()
  .argv;

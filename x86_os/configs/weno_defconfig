#
# Acrylic OS - AArch64 Kiosk Defconfig
#

# --- System Configuration
BR2_aarch64=y
BR2_TARGET_GENERIC_GETTY_PORT="ttyAMA0"
BR2_ROOTFS_DEVICE_CREATION_DYNAMIC_EUDEV=y
BR2_SYSTEM_DHCP="eth0"

# --- Toolchain (Optimized for space)
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN_AARCH64_GLIBC_STABLE=y

# --- Build options (Optimized for space)
BR2_DELETED_TMPDIR=y

# --- Kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="6.1.76"
# Use a generic ARM64 defconfig
BR2_LINUX_KERNEL_USE_ARCH_DEFAULT_CONFIG=y
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES=""

# --- Filesystem / Image
BR2_TARGET_ROOTFS_EXT4=y
BR2_TARGET_ROOTFS_EXT4_SIZE="512M"
BR2_TARGET_GRUB2_ARM64_EFI=y
BR2_PACKAGE_GRUB2=y
BR2_GRUB2_ARM64_EFI=y
BR2_LINUX_KERNEL_INSTALL_TARGET=y
BR2_TARGET_GENIMAGE=y
BR2_TARGET_GENIMAGE_CFG="board/weno-arm64/genimage.cfg"
BR2_TARGET_GENIMAGE_TMP_DIR="/tmp/genimage-weno"

# --- Target Packages
BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y

# --- Graphics and UI
BR2_PACKAGE_XORG_SERVER=y
BR2_PACKAGE_XSERVER_XORG_XINIT=y
BR2_PACKAGE_FLUXBOX=y
BR2_PACKAGE_WEBKITGTK=y
BR2_PACKAGE_SURF=y

# --- Fonts (required by browser)
BR2_PACKAGE_FONT_AWESOME=y
BR2_PACKAGE_LIBERATION=y

# --- Custom Overlay
BR2_EXTERNAL_WENO_PATH="$(BR2_EXTERNAL_PATH)"
BR2_ROOTFS_OVERLAY="../../x86_os/overlay"
BR2_POST_BUILD_SCRIPT="../../board/weno-arm64/post-build.sh"
